<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">

<bean  id="stdObj1" class="com.beans.Student">
	<property  name="sname"  value="Phani" />
	<property  name="course"  value="Java FSD" />
	<property  name="fees"  value="20000.00" />
</bean>

<bean  id="stdObj2" class="com.beans.Student">
	<property  name="sname"  value="Ravindra" />
	<property  name="course"  value="Python FSD" />
	<property  name="fees"  value="25000.00" />
</bean>


</beans>