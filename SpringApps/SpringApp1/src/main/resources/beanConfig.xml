<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">
                           
<!-- Constructor DI -->
<bean id="PerObj"  class="com.beans.Person">
	<constructor-arg name="pname" value="Satya"/>
	<constructor-arg name="email"  value="satya@gmail.com" />
</bean>

<!--  setter DI with injecting one class object into another class -->
<bean id ="AccObj"  class="com.beans.Account">
	<property name="AccNo" value="Acc001"/>
	<property name="BankName"  value="SBI" />
</bean>

<bean id="empObj"  class="com.beans.Employee">
	<property name="ename" value="Ravindra"/>
	<property name="job"  value="Developer" />
	<property name="sal"  value="12000.00" />
	<property name="acc"  ref="AccObj" />
</bean>

</beans>